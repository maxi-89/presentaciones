## Controllers

Controllers are **thin entry points**. Their only responsibilities:
1. Declare routes and HTTP methods via decorators
2. Extract and coerce request data using pipes
3. Delegate to services
4. Return typed response DTOs

```typescript
// src/modules/foo/foo.controller.ts
import {
  Controller,
  Get,
  Post,
  Body,
  Param,
  ParseUUIDPipe,
  HttpCode,
  HttpStatus,
} from '@nestjs/common';
import { FooService } from './foo.service';
import { CreateFooDto } from './dto/create-foo.dto';
import { FooResponseDto } from './dto/foo-response.dto';

@Controller('foos')
export class FooController {
  constructor(private readonly fooService: FooService) {}

  @Post()
  @HttpCode(HttpStatus.CREATED)
  async create(@Body() dto: CreateFooDto): Promise<FooResponseDto> {
    return this.fooService.create(dto);
  }

  @Get(':id')
  async findOne(@Param('id', ParseUUIDPipe) id: string): Promise<FooResponseDto> {
    return this.fooService.findById(id);
  }
}
```

**Rules:**
- No business logic in controllers
- Use NestJS built-in pipes (`ParseUUIDPipe`, `ParseIntPipe`) for parameter coercion
- Explicitly declare return types
- Use `@HttpCode` to set non-default status codes (e.g. 201, 204)

