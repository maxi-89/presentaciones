## Infrastructure Layer

### DynamoDB Client Provider

```typescript
// src/infrastructure/dynamodb/dynamodb.provider.ts
import type { Provider } from '@nestjs/common';
import { ConfigService } from '@nestjs/config';
import { DynamoDBClient } from '@aws-sdk/client-dynamodb';
import { DynamoDBDocumentClient } from '@aws-sdk/lib-dynamodb';

export const DYNAMODB_CLIENT = Symbol('DynamoDBDocumentClient');

export const DynamodbProvider: Provider = {
  provide: DYNAMODB_CLIENT,
  inject: [ConfigService],
  useFactory: (config: ConfigService): DynamoDBDocumentClient => {
    const endpoint = config.get<string>('dynamodb.endpoint');
    const client = new DynamoDBClient({
      region: config.get<string>('dynamodb.region'),
      ...(endpoint && {
        endpoint,
        credentials: { accessKeyId: 'local', secretAccessKey: 'local' },
      }),
    });
    return DynamoDBDocumentClient.from(client);
  },
};
```

### Repository Implementation

```typescript
// src/infrastructure/dynamodb/foo.repository.ts
import { Injectable, Inject } from '@nestjs/common';
import { ConfigService } from '@nestjs/config';
import { DynamoDBDocumentClient, PutCommand, GetCommand } from '@aws-sdk/lib-dynamodb';
import { IFooRepository } from '../../domain/repositories/IFooRepository';
import { Foo } from '../../domain/models/Foo';
import { DYNAMODB_CLIENT } from './dynamodb.provider';

@Injectable()
export class FooRepository implements IFooRepository {
  private readonly tableName: string;

  constructor(
    @Inject(DYNAMODB_CLIENT) private readonly client: DynamoDBDocumentClient,
    config: ConfigService,
  ) {
    this.tableName = config.getOrThrow<string>('dynamodb.tableName');
  }

  async save(foo: Foo): Promise<void> {
    await this.client.send(
      new PutCommand({
        TableName: this.tableName,
        Item: {
          PK: `FOO#${foo.id}`,
          SK: `FOO#${foo.id}`,
          id: foo.id,
          name: foo.name,
          createdAt: foo.createdAt,
          entityType: 'FOO',
        },
      }),
    );
  }

  async findById(id: string): Promise<Foo | null> {
    const result = await this.client.send(
      new GetCommand({
        TableName: this.tableName,
        Key: { PK: `FOO#${id}`, SK: `FOO#${id}` },
      }),
    );

    if (!result.Item) return null;

    return new Foo({
      id: result.Item['id'] as string,
      name: result.Item['name'] as string,
      createdAt: result.Item['createdAt'] as string,
    });
  }

  async findAll(): Promise<Foo[]> {
    return [];
  }
}
```

