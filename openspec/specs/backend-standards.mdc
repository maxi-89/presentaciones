## Exception Handling

### Global Exception Filter

```typescript
// src/common/filters/http-exception.filter.ts
import {
  ExceptionFilter,
  Catch,
  ArgumentsHost,
  HttpException,
  HttpStatus,
  Logger,
} from '@nestjs/common';
import type { Request, Response } from 'express';

@Catch()
export class HttpExceptionFilter implements ExceptionFilter {
  private readonly logger = new Logger(HttpExceptionFilter.name);

  catch(exception: unknown, host: ArgumentsHost): void {
    const ctx = host.switchToHttp();
    const response = ctx.getResponse<Response>();
    const request = ctx.getRequest<Request>();

    const status =
      exception instanceof HttpException
        ? exception.getStatus()
        : HttpStatus.INTERNAL_SERVER_ERROR;

    const message =
      exception instanceof HttpException
        ? exception.message
        : 'Internal server error';

    if (status >= 500) {
      this.logger.error(`${request.method} ${request.url}`, exception);
    }

    response.status(status).json({ error: message });
  }
}
```

### HTTP Status Code Mapping

| Situation | NestJS Exception | Status |
|---|---|---|
| Invalid input | `BadRequestException` | 400 |
| Unauthorized | `UnauthorizedException` | 401 |
| Forbidden | `ForbiddenException` | 403 |
| Not found | `NotFoundException` | 404 |
| Conflict | `ConflictException` | 409 |
| Unhandled | (filter catches) | 500 |

**Rules:**
- Always throw NestJS `HttpException` subclasses from services — never raw `Error`
- Let the global filter handle all error serialization
- All error responses follow the shape: `{ "error": "Human-readable message" }`

