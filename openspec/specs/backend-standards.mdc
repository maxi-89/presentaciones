## NestJS Module Organization

Each feature is encapsulated in a **NestJS module**. Modules are the primary unit of organization.

```typescript
// src/modules/foo/foo.module.ts
import { Module } from '@nestjs/common';
import { FooController } from './foo.controller';
import { FooService } from './foo.service';
import { FooRepository } from '../../infrastructure/dynamodb/foo.repository';
import { FOO_REPOSITORY } from '../../domain/repositories/IFooRepository';

@Module({
  controllers: [FooController],
  providers: [
    FooService,
    { provide: FOO_REPOSITORY, useClass: FooRepository },
  ],
})
export class FooModule {}
```

```typescript
// src/app.module.ts
import { Module } from '@nestjs/common';
import { ConfigModule } from '@nestjs/config';
import { FooModule } from './modules/foo/foo.module';
import configuration from './config/configuration';

@Module({
  imports: [
    ConfigModule.forRoot({ isGlobal: true, load: [configuration] }),
    FooModule,
  ],
})
export class AppModule {}
```

