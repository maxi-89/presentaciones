## Testing Standards

### Coverage Threshold

Minimum 90% for branches, functions, lines, and statements.

### Structure

```
test/
├── unit/
│   └── modules/
│       └── foo/
│           ├── foo.service.spec.ts
│           └── foo.controller.spec.ts
└── e2e/
    └── foo.e2e-spec.ts
```

### Service Unit Test Pattern

Use `@nestjs/testing` to create isolated testing modules:

```typescript
// test/unit/modules/foo/foo.service.spec.ts
import { Test, TestingModule } from '@nestjs/testing';
import { NotFoundException } from '@nestjs/common';
import { FooService } from '../../../../src/modules/foo/foo.service';
import { IFooRepository, FOO_REPOSITORY } from '../../../../src/domain/repositories/IFooRepository';

const mockFooRepository: jest.Mocked<IFooRepository> = {
  save: jest.fn(),
  findById: jest.fn(),
  findAll: jest.fn(),
};

describe('FooService', () => {
  let service: FooService;

  beforeEach(async () => {
    const module: TestingModule = await Test.createTestingModule({
      providers: [
        FooService,
        { provide: FOO_REPOSITORY, useValue: mockFooRepository },
      ],
    }).compile();

    service = module.get<FooService>(FooService);
    jest.clearAllMocks();
  });

  describe('create', () => {
    it('saves a new Foo and returns its id', async () => {
      // Arrange
      mockFooRepository.save.mockResolvedValue(undefined);

      // Act
      const result = await service.create({ name: 'Test' });

      // Assert
      expect(result.id).toBeDefined();
      expect(mockFooRepository.save).toHaveBeenCalledTimes(1);
    });
  });

  describe('findById', () => {
    it('throws NotFoundException when Foo does not exist', async () => {
      mockFooRepository.findById.mockResolvedValue(null);

      await expect(service.findById('nonexistent-id')).rejects.toThrow(NotFoundException);
    });
  });
});
```

### Controller Unit Test Pattern

```typescript
// test/unit/modules/foo/foo.controller.spec.ts
import { Test, TestingModule } from '@nestjs/testing';
import { FooController } from '../../../../src/modules/foo/foo.controller';
import { FooService } from '../../../../src/modules/foo/foo.service';

const mockFooService = {
  create: jest.fn(),
  findById: jest.fn(),
};

describe('FooController', () => {
  let controller: FooController;

  beforeEach(async () => {
    const module: TestingModule = await Test.createTestingModule({
      controllers: [FooController],
      providers: [{ provide: FooService, useValue: mockFooService }],
    }).compile();

    controller = module.get<FooController>(FooController);
    jest.clearAllMocks();
  });

  describe('create', () => {
    it('delegates to FooService.create and returns the result', async () => {
      const dto = { name: 'Test' };
      const expected = { id: 'abc', name: 'Test', createdAt: '2026-01-01T00:00:00.000Z' };
      mockFooService.create.mockResolvedValue(expected);

      const result = await controller.create(dto);

      expect(result).toEqual(expected);
      expect(mockFooService.create).toHaveBeenCalledWith(dto);
    });
  });
});
```

### E2E Test Pattern

```typescript
// test/e2e/foo.e2e-spec.ts
import { Test, TestingModule } from '@nestjs/testing';
import { INestApplication, ValidationPipe } from '@nestjs/common';
import * as request from 'supertest';
import { AppModule } from '../../src/app.module';

describe('FooController (e2e)', () => {
  let app: INestApplication;

  beforeAll(async () => {
    const module: TestingModule = await Test.createTestingModule({
      imports: [AppModule],
    }).compile();

    app = module.createNestApplication();
    app.useGlobalPipes(new ValidationPipe({ whitelist: true, transform: true }));
    await app.init();
  });

  afterAll(async () => {
    await app.close();
  });

  it('POST /foos — returns 201 on valid input', () => {
    return request(app.getHttpServer())
      .post('/foos')
      .send({ name: 'Test' })
      .expect(201)
      .expect((res) => {
        expect((res.body as { id: string }).id).toBeDefined();
      });
  });

  it('POST /foos — returns 400 on invalid input', () => {
    return request(app.getHttpServer()).post('/foos').send({ name: '' }).expect(400);
  });
});
```

**Rules:**
- Use `@nestjs/testing` for all unit and e2e tests — never instantiate classes manually
- Follow **AAA (Arrange, Act, Assert)** in unit tests
- Always `jest.clearAllMocks()` in `beforeEach`
- E2E tests must mirror the global pipes and filters configured in `main.ts`

