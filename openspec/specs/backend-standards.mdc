## Services (Application Layer)

Services orchestrate domain logic via constructor injection. They are the boundary between presentation and domain.

```typescript
// src/modules/foo/foo.service.ts
import { Injectable, Inject, NotFoundException } from '@nestjs/common';
import { v4 as uuidv4 } from 'uuid';
import { IFooRepository, FOO_REPOSITORY } from '../../domain/repositories/IFooRepository';
import { Foo } from '../../domain/models/Foo';
import { CreateFooDto } from './dto/create-foo.dto';
import { FooResponseDto } from './dto/foo-response.dto';

@Injectable()
export class FooService {
  constructor(
    @Inject(FOO_REPOSITORY) private readonly fooRepository: IFooRepository,
  ) {}

  async create(dto: CreateFooDto): Promise<FooResponseDto> {
    const foo = new Foo({
      id: uuidv4(),
      name: dto.name,
      createdAt: new Date().toISOString(),
    });

    await this.fooRepository.save(foo);

    return { id: foo.id, name: foo.name, createdAt: foo.createdAt };
  }

  async findById(id: string): Promise<FooResponseDto> {
    const foo = await this.fooRepository.findById(id);

    if (!foo) {
      throw new NotFoundException(`Foo with id ${id} not found`);
    }

    return { id: foo.id, name: foo.name, createdAt: foo.createdAt };
  }
}
```

**Rules:**
- Always use constructor injection; use `@Inject(TOKEN)` for interface-bound dependencies
- Use NestJS built-in HTTP exceptions (`NotFoundException`, `BadRequestException`, `ConflictException`) — never throw raw `Error`
- Services must not import HTTP decorators, `@Controller`, or AWS SDK directly
- Return typed response DTOs from service methods — never expose domain entities

